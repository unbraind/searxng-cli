{
  "name": "searxng-cli",
  "version": "2026.3.6-3",
  "description": "SearXNG CLI - Enhanced TypeScript search client for SearXNG instances with TOON format support, persistent caching, and AI agent mode",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "searxng-cli": "./dist/searxng-cli.js",
    "searxng": "./dist/searxng-cli.js"
  },
  "scripts": {
    "build": "bash scripts/build.sh",
    "build:full": "bun run build && tsc --emitDeclarationOnly --declaration",
    "build:watch": "tsc --watch",
    "start": "node dist/searxng-cli.js",
    "dev": "bun src/searxng-cli.ts",
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "test:coverage": "bash scripts/test-coverage.sh",
    "test:e2e:live": "vitest run tests/e2e/cli.test.ts",
    "test:e2e:searxng": "bash scripts/e2e-searxng.sh",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build",
    "lint": "bun run typecheck && bun run format:check",
    "version:sync": "bash scripts/sync-version.sh",
    "version:check": "bash scripts/version-check.sh",
    "version:audit": "bash scripts/version-audit-tags.sh",
    "release:check": "bash scripts/release-check.sh",
    "secrets:history": "bash scripts/secret-scan-history.sh",
    "smoke:package": "bash scripts/package-smoke.sh",
    "release:dry-run": "bash scripts/release-dry-run.sh"
  },
  "keywords": [
    "searxng",
    "search",
    "cli",
    "metasearch",
    "privacy",
    "toon",
    "typescript",
    "llm",
    "ai-agent",
    "search-engine",
    "searx",
    "web-search",
    "terminal",
    "command-line",
    "caching",
    "toon-format",
    "bun"
  ],
  "author": "SearXNG CLI Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unbraind/searxng-cli.git"
  },
  "bugs": {
    "url": "https://github.com/unbraind/searxng-cli/issues"
  },
  "homepage": "https://github.com/unbraind/searxng-cli#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "bun@1.2.0",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "3.2.0",
    "esbuild": "^0.27.3",
    "prettier": "^3.4.0",
    "typescript": "^5.9.0",
    "vitest": "3.2.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@toon-format/toon": "^2.1.0",
    "cac": "^7.0.0",
    "commander": "^14.0.3",
    "node-html-parser": "^7.1.0"
  }
}
